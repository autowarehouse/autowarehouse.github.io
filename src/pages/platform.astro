---
import PageLayout from '@layouts/PageLayout.astro';
import Badge from '@components/ui/Badge.astro';
import GradientOrb from '@components/ui/GradientOrb.astro';
import PipelineBar from '@components/ui/PipelineBar.astro';
import TechStackGrid from '@components/common/TechStackGrid.astro';

const techStack = [
  { name: 'Enterprise Web Platform', description: 'Multi-tenant UI with role-based dashboards and real-time collaboration' },
  { name: 'AI Agent Engine', description: 'Multi-agent orchestration for discovery, mapping, and documentation' },
  { name: 'LLM Gateway', description: 'Local-first LLM integration — Ollama, vLLM, LiteLLM, or any compatible runtime' },
  { name: 'Data Profiling Engine', description: 'Automated database discovery, column profiling, anomaly detection' },
  { name: 'ETL Code Generator', description: 'Deterministic, plugin-based exporters for Airflow, dbt, Snowflake, Spark, PL/SQL' },
  { name: 'Data Quality Engine', description: 'Null analysis, cardinality checks, anomaly flags, completeness scoring' },
  { name: 'Metadata Store', description: 'PostgreSQL with vector extensions for semantic search and audit trails' },
  { name: 'Container-Native', description: 'Docker Compose and Kubernetes-ready with Helm charts' },
];

const security = [
  { icon: '🔐', title: 'AES-256-GCM', desc: 'Encryption for all credentials' },
  { icon: '🔑', title: 'OIDC-First Auth', desc: 'Keycloak, Auth0, LDAP support' },
  { icon: '🛡️', title: 'RBAC', desc: '30+ granular permissions' },
  { icon: '📋', title: 'Audit Logging', desc: 'Full traceability for every AI decision and data operation' },
];
---

<PageLayout title="Platform" description="AutoWarehouse platform architecture: self-hosted, multi-tenant, AI-powered. Tech stack, security (AES-256-GCM, RBAC), deployment options, and Intellica ecosystem integration.">
  <!-- Hero -->
  <section class="relative overflow-hidden py-20">
    <GradientOrb color="blue" size="400px" position="top: -100px; right: -100px;" />
    <div class="relative z-10 mx-auto max-w-3xl px-6 text-center">
      <Badge>Platform Overview</Badge>
      <h1 class="mt-4 text-3xl font-extrabold text-white md:text-5xl">Built for Enterprise Data</h1>
      <p class="mt-4 text-base text-slate-400">
        Multi-tenant, AI-powered, self-hosted. One platform from source ingestion to business intelligence.
      </p>
    </div>
  </section>

  <!-- Pipeline -->
  <section class="bg-[var(--bg-secondary)] py-8">
    <PipelineBar />
  </section>

  <!-- Tech Stack -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-8 text-center text-2xl font-extrabold text-white">Platform Capabilities</h2>
      <TechStackGrid items={techStack} />
    </div>
  </section>

  <!-- Security -->
  <section class="bg-[var(--bg-secondary)] py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-8 text-center text-2xl font-extrabold text-white">Security & Compliance</h2>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {security.map((s) => (
          <div class="glass-card rounded-xl p-5 text-center">
            <div class="text-2xl">{s.icon}</div>
            <div class="mt-2 text-sm font-semibold text-white">{s.title}</div>
            <div class="mt-1 text-xs text-slate-400">{s.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Intellica Ecosystem -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-3 text-center text-2xl font-extrabold text-white">Intellica Ecosystem</h2>
      <p class="mb-8 text-center text-sm text-slate-400">
        AutoWarehouse integrates with and builds upon Intellica's proven product family
      </p>
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="glass-card rounded-xl p-5">
          <div class="text-xs font-semibold text-blue-400">Data Models</div>
          <div class="mt-1 text-sm font-semibold text-white">IFDM · ITDM · HRDM</div>
          <p class="mt-2 text-xs text-slate-400">Industry-standard warehouse models for Finance, Telecom, and HR — refined across dozens of deployments</p>
        </div>
        <div class="glass-card rounded-xl p-5">
          <div class="text-xs font-semibold text-purple-400">Quality</div>
          <div class="mt-1 text-sm font-semibold text-white">ICC</div>
          <p class="mt-2 text-xs text-slate-400">Central data consistency management — reconciliation rules, quality gates, and drift monitoring</p>
        </div>
        <div class="glass-card rounded-xl p-5">
          <div class="text-xs font-semibold text-pink-400">NL Analytics</div>
          <div class="mt-1 text-sm font-semibold text-white">Talk To</div>
          <p class="mt-2 text-xs text-slate-400">Natural language data interaction — ask questions, get SQL queries and visualizations instantly</p>
        </div>
        <div class="glass-card rounded-xl p-5">
          <div class="text-xs font-semibold text-green-400">Orchestration</div>
          <div class="mt-1 text-sm font-semibold text-white">Orqenta</div>
          <p class="mt-2 text-xs text-slate-400">Workflow orchestration and automation for regulated environments and complex data pipelines</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Deployment -->
  <section class="bg-[var(--bg-secondary)] py-16">
    <div class="mx-auto max-w-6xl px-6">
      <h2 class="mb-3 text-center text-2xl font-extrabold text-white">Deploy Your Way</h2>
      <p class="mb-10 text-center text-sm text-slate-400">
        Self-hosted on your infrastructure. No cloud lock-in. Choose the topology that fits your scale.
      </p>

      <!-- Deployment Tiers -->
      <div class="grid gap-4 md:grid-cols-3">
        <!-- Dev / POC -->
        <div class="glass-card rounded-xl p-6">
          <div class="text-[10px] font-semibold uppercase tracking-[2px] text-blue-400">Development & POC</div>
          <h3 class="mt-2 text-sm font-bold text-white">Single Machine</h3>
          <p class="mt-2 text-xs text-slate-400">Docker Compose on a single VM or laptop. Ideal for evaluation, development, and proof-of-concept deployments.</p>
          <div class="mt-4 rounded-lg bg-black/30 p-3">
            <code class="block text-[11px] leading-relaxed text-slate-300">
              <span class="text-slate-500">$</span> docker compose up -d<br />
              <span class="text-green-400">✓</span> autowarehouse-db — metadata & vector store<br />
              <span class="text-green-400">✓</span> autowarehouse-web — application server<br />
              <span class="text-green-400">✓</span> autowarehouse-worker — ETL processing engine<br />
              <span class="text-green-400">✓</span> autowarehouse-llm — local LLM runtime
            </code>
          </div>
          <div class="mt-3 text-[10px] text-slate-500">Min: 4 vCPU · 16 GB RAM · 100 GB SSD</div>
        </div>

        <!-- Production -->
        <div class="glass-card rounded-xl border-blue-500/20 p-6">
          <div class="text-[10px] font-semibold uppercase tracking-[2px] text-purple-400">Production</div>
          <h3 class="mt-2 text-sm font-bold text-white">Multi-Container</h3>
          <p class="mt-2 text-xs text-slate-400">Isolated services with dedicated resources, external database, and self-hosted LLM runtime. Production-ready with monitoring.</p>
          <div class="mt-4 space-y-1.5 text-[11px] text-slate-300">
            <div class="flex items-center gap-2"><span class="text-purple-400">◆</span> External PostgreSQL (RDS, Cloud SQL, on-prem)</div>
            <div class="flex items-center gap-2"><span class="text-purple-400">◆</span> Horizontal worker scaling (N ETL workers)</div>
            <div class="flex items-center gap-2"><span class="text-purple-400">◆</span> Local LLM: Ollama, vLLM, or LiteLLM</div>
            <div class="flex items-center gap-2"><span class="text-purple-400">◆</span> Reverse proxy (Nginx / Traefik) + TLS</div>
            <div class="flex items-center gap-2"><span class="text-purple-400">◆</span> Log aggregation & health checks</div>
          </div>
          <div class="mt-3 text-[10px] text-slate-500">Rec: 8+ vCPU · 32+ GB RAM · HA storage</div>
        </div>

        <!-- Enterprise / K8s -->
        <div class="glass-card rounded-xl p-6">
          <div class="text-[10px] font-semibold uppercase tracking-[2px] text-green-400">Enterprise Scale</div>
          <h3 class="mt-2 text-sm font-bold text-white">Kubernetes</h3>
          <p class="mt-2 text-xs text-slate-400">Helm charts for full Kubernetes orchestration. Auto-scaling, multi-tenant isolation, and enterprise-grade observability.</p>
          <div class="mt-4 space-y-1.5 text-[11px] text-slate-300">
            <div class="flex items-center gap-2"><span class="text-green-400">◆</span> Helm chart with configurable values</div>
            <div class="flex items-center gap-2"><span class="text-green-400">◆</span> HPA auto-scaling (web + workers)</div>
            <div class="flex items-center gap-2"><span class="text-green-400">◆</span> Namespace-level tenant isolation</div>
            <div class="flex items-center gap-2"><span class="text-green-400">◆</span> Prometheus + Grafana monitoring</div>
            <div class="flex items-center gap-2"><span class="text-green-400">◆</span> Backup & disaster recovery</div>
          </div>
          <div class="mt-3 text-[10px] text-slate-500">EKS · AKS · GKE · On-prem K8s</div>
        </div>
      </div>

      <!-- Architecture Diagram -->
      <div class="mt-10 glass-card rounded-xl p-6">
        <div class="mb-4 text-center text-[10px] font-semibold uppercase tracking-[2px] text-slate-500">Platform Architecture</div>
        <div class="grid gap-3 md:grid-cols-4">
          <div class="rounded-lg bg-blue-500/10 border border-blue-500/20 p-3 text-center">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-blue-400">Presentation</div>
            <div class="mt-1 text-xs text-slate-300">Web Application</div>
            <div class="mt-0.5 text-[10px] text-slate-500">Dashboards · Data Studio · Auth</div>
          </div>
          <div class="rounded-lg bg-purple-500/10 border border-purple-500/20 p-3 text-center">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-purple-400">AI Engine</div>
            <div class="mt-1 text-xs text-slate-300">Multi-Agent Orchestration</div>
            <div class="mt-0.5 text-[10px] text-slate-500">Discovery · Mapping · NL-SQL</div>
          </div>
          <div class="rounded-lg bg-green-500/10 border border-green-500/20 p-3 text-center">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-green-400">ETL Runtime</div>
            <div class="mt-1 text-xs text-slate-300">Worker Pool + Code Generator</div>
            <div class="mt-0.5 text-[10px] text-slate-500">Execution · Profiling · Export</div>
          </div>
          <div class="rounded-lg bg-yellow-500/10 border border-yellow-500/20 p-3 text-center">
            <div class="text-[10px] font-semibold uppercase tracking-wider text-yellow-400">Data Layer</div>
            <div class="mt-1 text-xs text-slate-300">Metadata & Vector Store</div>
            <div class="mt-0.5 text-[10px] text-slate-500">Catalog · Embeddings · Audit</div>
          </div>
        </div>
      </div>

      <!-- Key Principles -->
      <div class="mt-6 grid gap-3 md:grid-cols-3">
        <div class="flex items-start gap-3 rounded-lg p-3">
          <span class="mt-0.5 text-lg">🔓</span>
          <div>
            <div class="text-xs font-semibold text-white">Data Sovereignty</div>
            <div class="text-[11px] text-slate-400">Your data never leaves your infrastructure. No external API calls required — run LLMs locally with Ollama, vLLM, or LiteLLM.</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-lg p-3">
          <span class="mt-0.5 text-lg">📈</span>
          <div>
            <div class="text-xs font-semibold text-white">Elastic Scaling</div>
            <div class="text-[11px] text-slate-400">Scale ETL workers independently from the web tier. Process 10 tables or 10,000 — the architecture adapts to your workload.</div>
          </div>
        </div>
        <div class="flex items-start gap-3 rounded-lg p-3">
          <span class="mt-0.5 text-lg">🔄</span>
          <div>
            <div class="text-xs font-semibold text-white">Zero Downtime Updates</div>
            <div class="text-[11px] text-slate-400">Rolling deployments with database migrations. Update the platform without interrupting running ETL jobs or active sessions.</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
